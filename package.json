{
  "name": "otp-vault-mono",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @otp-vault/web dev",
    "dev:ext": "yarn workspace @otp-vault/extension dev",
    "build:web": "yarn workspace @otp-vault/web build",
    "build:ext": "yarn workspace @otp-vault/extension build",
    "build": "yarn build:web && yarn build:ext",
    "deploy": "vercel --prod"
  },
  "resolutions": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.577.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  },
  "packageManager": "yarn@4.9.1",
  "dependencies": {
    "vercel": "^50.33.0"
  }
}
